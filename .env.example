# =============================================================================
# 复制为 `.env` 后按需填写（`.env` 已被 gitignore）。
#
# 三种本地运行方式（任选其一）：
# -----------------------------------------------------------------------------
# ① npm run dev          → 纯 Vite，无 Cloudflare Worker 绑定。
#                            数据库/OCR 队列等 Worker API 不可用或降级；auth 依赖
#                            process.env 回退（见 hooks）。适合只改 UI。
# ② npm run dev:cf       → 构建后用 Wrangler 本地 Worker（推荐全功能）。
#                            读 `wrangler.jsonc` + `.dev.vars`，不读本文件。
# ③ npm run preview      → 先 build 再 Wrangler（端口 4173），用于验收构建产物。
#                            同样用 `.dev.vars`，不用本文件。
#
# 规则：密钥类变量若两种都要测，请在 `.env` 与 `.dev.vars` 各写一份并保持同名
# 变量值一致（Wrangler 不会自动加载 `.env`）。
# =============================================================================

# --- better-auth（仅 Vite 模式需要；dev:cf 请写在 `.dev.vars`）---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# --- Drizzle / wrangler CLI（与 wrangler.jsonc 中 account、D1 id 一致）---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=

# --- OCR / LLM（Vite 下 readEnv 可读到；dev:cf 请同步到 `.dev.vars`）---
OCR_PROVIDER=mock
OCR_API_URL=
OCR_API_KEY=
LLM_PROVIDER=heuristic
LLM_API_URL=
LLM_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OCR_PROMPT_VERSION=v1
# LLM_SKIP_WORKERS=true
# LLM_USE_EXTERNAL=false
