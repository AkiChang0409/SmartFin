{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "smartfin",
	"account_id": "c09bb2823904032b6ec648b23411f2e0",
	"compatibility_date": "2026-03-30",
	"compatibility_flags": [
		"nodejs_als"
	],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "smartfin-db",
			"database_id": "208e1ed4-437f-4da5-93d7-7058debea5c8",
			"migrations_dir": "drizzle/migrations"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "smartfin-files"
		}
	],
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "fd0eca3363a3444daff52d1a35af69eb"
		}
	],
	"queues": {
		"producers": [
			{
			"binding": "OCR_QUEUE",
			"queue": "smartfin-ocr-queue"  
			}
		],
		"consumers": [
			{
			"queue": "smartfin-ocr-queue",  
			"dead_letter_queue": "smartfin-ocr-queue-dlq"
			}
		]
	},
	"vars": {
		"BETTER_AUTH_URL": "https://smartfin.smartfin.workers.dev",
		"LLM_PROVIDER": "heuristic",
		"WORKERS_AI_MODEL": "@cf/meta/llama-3.1-8b-instruct",
		"OCR_PROMPT_VERSION": "v1"
	},
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"ai": { "binding": "AI" },
	"workers_dev": true,
	"preview_urls": true
}